{
  "name": "@tychilabs/ugf-sdk",
  "version": "2.0.0",
  "description": "Gasless transactions for AI agents and Web3 apps — pay gas in stablecoins or native EVM coins across any chain via Universal Gas Framework",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@mysten/sui": "^2.13.0",
    "@solana/web3.js": "^1.95.0",
    "ethers": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "@mysten/sui": {
      "optional": true
    },
    "@solana/web3.js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@mysten/sui": "^2.13.2",
    "@solana/web3.js": "^1.95.0",
    "@types/node": "^20.0.0",
    "ethers": "^6.13.0",
    "tsup": "^8.5.1",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "ugf",
    "universal-gas-framework",
    "gas-abstraction",
    "gasless",
    "multichain",
    "web3",
    "ethereum",
    "solana",
    "sui",
    "evm",
    "x402",
    "defi",
    "agentic",
    "ai-agents",
    "gas-sponsorship",
    "stablecoin",
    "x402-protocol",
    "$u",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/TychiWallet/ugf-sdk-v2"
  },
  "homepage": "https://universalgasframework.com",
  "bugs": {
    "url": "https://github.com/TychiWallet/ugf-sdk-v2/issues"
  },
  "license": "Apache-2.0"
}
